# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# NCBI
NCBI_API_KEY=                         # optional, raises rate limit 3->10 req/s

# Models
SYNTHESIS_MODEL=anthropic/claude-sonnet-4.6
CITATION_CHECK_MODEL=anthropic/claude-haiku-4.5
EMBEDDING_MODEL=openai/text-embedding-3-small   # Phase 2 — semantic search (ADR-0008)
EXTRACTION_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free  # Feature 2 relation verdict; FREE slug so the always-on backfill costs $0 (swap to a paid slug for higher precision)

# App config
TISSUES=whole_blood,liver,brain_prefrontal_cortex
DOROTHEA_MIN_CONFIDENCE=A,B
CITATION_AGENT_BATCH_SIZE=100
CITATION_AGENT_CRON_HOUR=0            # midnight UTC
EMBEDDING_AGENT_CRON_ENABLED=false   # nightly embedding crawl spends OpenRouter $; off by default. Run on demand via POST /admin/agents/embedding/run
EXTRACTION_AGENT_ENABLED=false       # Feature 2 literature extractor + backfill (spends NCBI; LLM is free by default). Off by default; triggers/crons refuse unless true
EXTRACTION_LLM_CONCURRENCY=8         # concurrent relation-verdict LLM calls in flight (sized to saturate the rate limit at ~27s latency, not to burst)
EXTRACTION_LLM_RATE_PER_MIN=15       # pace LLM calls under the free tier's account-wide 16/min cap (raise for a paid model)
EXTRACTION_LLM_TIMEOUT_S=120         # per-verdict LLM timeout; a slow/queued free model can't block a chunk (hung verdict dropped + chunk retried)
EXTRACTION_DATE_TYPE=edat            # PubMed date field the cursor walks; edat (entry date) avoids pdat's year-only Jan-1 pile-up that would truncate the backfill
EXTRACTION_BACKFILL_FLOOR_DATE=2005-01-01  # oldest entry date the historical backfill will reach
EXTRACTION_BACKFILL_CHUNK_DAYS=7     # backward-walk window width (auto-shrinks if a window is too dense)
EXTRACTION_FORWARD_CHUNK_DAYS=1      # nightly forward catch-up window width
EXTRACTION_FORWARD_LAG_DAYS=2        # trailing buffer for PubMed indexing lag (don't chase papers indexed after 'today')
EXTRACTION_MAX_PMIDS_PER_CHUNK=5000  # per-window esearch count cap; halve the window until it fits
EXTRACTION_HTTP_MAX_RETRIES=4        # NCBI/LLM transient-error retries (honours 429 Retry-After)
EXTRACTION_HTTP_BACKOFF_S=1.0        # base exponential backoff seconds
EXTRACTION_BACKFILL_CRON_HOUR=3      # nightly forward-catchup cron hour (UTC)
LITERATURE_CONDUCTANCE_FACTOR=0.5    # promoted literature edges conduct less signal than canonical (ADR-0013)
VALIDATION_AUTO_PROMOTE_ENABLED=false # auto-promote candidates to trusted edges. Off (uncalibrated); use manual approve/reject
ADMIN_TOKEN=                          # gate for the /admin review dashboard (ADR-0014). Empty=open (local dev); set a secret on any shared/public host
ADMIN_FAIL_CLOSED=false               # ADR-0017: set true on public hosts — empty ADMIN_TOKEN then REFUSES /admin (503) instead of falling open
DEFAULT_GENE=TP53                     # pre-loaded on frontend
TISSUE_WEIGHT_THRESHOLD=0.3           # min weight for edge visibility
STRING_MIN_CONFIDENCE=0.95           # PPI confidence (0-1); 0.95 since 05_proteins mints the full proteome (ADR-0010)

# Phase 3 ETL thresholds (08_phase3_build_prompt.md) — never hardcode these.
TCGA_MIN_LOG2FC=1.0                   # min |log2FC| for DIFFERENTIALLY_EXPRESSED edges
TCGA_MAX_ADJ_PVALUE=0.05             # adjusted p-value cutoff (reserved)
TCGA_MIN_TUMORS=10                    # min tumour samples a cohort needs to be processed
TCGA_MIN_NORMALS=10                   # min adjacent-normal samples (cohorts below are skipped)
METABOLOMICS_MIN_REACTIONS=1         # min reactions a metabolite must appear in to load
ENCODE_BATCH_SIZE=5000              # cCRE nodes per Cypher UNWIND (Phase 9, gated)

# Variant-level gnomAD allele frequency (16_gnomad_af.py — Ensembl REST crawl).
# pops=1 returns ~148 populations/variant, so 200-id batches exceed a 60s read; 50 is
# the measured sweet spot (~19s/batch, ~100% gnomAD-ALL hit). Long resumable backfill.
GNOMAD_AF_BATCH_SIZE=50              # rsIDs per Ensembl POST (cap 200; 50 = sweet spot)
GNOMAD_AF_REQUEST_DELAY_S=0.1        # polite delay between batches (~15 req/s soft limit)
GNOMAD_AF_TIMEOUT_S=90               # per-request read timeout (heavy pops=1 response)

# Metabolite "bridge" connectivity (ADR-0012, amends ADR-0011). Default OFF — the
# ADR-0011 leaf rule is the tuned default. When on, a discovered metabolite expands
# once to its co-catalysing proteins, gated by Metabolite.catalyses_degree (data-driven
# cofactor cutoff) and dense-capped, so hub cofactors (ATP/NAD+/H2O) can't flood.
METABOLITE_BRIDGE_ENABLED=false      # master opt-in for the shared-substrate bridge
CATALYSES_MAX_EXPAND_PER_NODE=8      # co-catalysing proteins a metabolite expands to per ring
METABOLITE_MAX_CATALYSES_DEGREE=30   # metabolites above this CATALYSES degree never expand
