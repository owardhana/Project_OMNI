# Multi-stage: build the frontend, then serve it (+ reverse-proxy the API) with Caddy.
# Build context is the repo root (see docker-compose.prod.yml) so we can copy frontend/.

# ---- stage 1: build the Vite SPA ----
FROM node:22-slim AS build
WORKDIR /app
COPY frontend/package*.json ./
RUN npm install --no-audit --no-fund
COPY frontend/ ./
# Empty API base -> same-origin relative /api calls, which Caddy proxies (client.ts).
ENV VITE_API_URL=""
RUN npm run build   # tsc -b && vite build -> /app/dist

# ---- stage 2: Caddy serves the static build + proxies /api ----
FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
